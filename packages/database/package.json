{
	"name": "@repo/database",
	"version": "0.0.0",
	"main": "./index.ts",
	"types": "./index.ts",
	"scripts": {
		"clean": "git clean -xdf .cache .turbo dist node_modules",
		"push": "dotenv -c -e ../../.env -e ../../.env.local -- drizzle-kit push",
		"db:generate": "dotenv -c -e ../../.env -e ../../.env.local -- drizzle-kit generate",
		"db:migrate": "dotenv -c -e ../../.env -e ../../.env.local -- drizzle-kit migrate",
		"db:studio": "dotenv -c -e ../../.env -e ../../.env.local -- drizzle-kit studio",
		"type-check": "tsc --noEmit"
	},
	"dependencies": {
		"@paralleldrive/cuid2": "^3.3.0",
		"dotenv": "^17.4.2",
		"drizzle-orm": "catalog:",
		"drizzle-zod": "catalog:",
		"pg": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@repo/tsconfig": "workspace:*",
		"@types/node": "catalog:",
		"dotenv-cli": "catalog:",
		"drizzle-kit": "catalog:"
	}
}
