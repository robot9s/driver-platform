{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"arrowParens": "always",
	"printWidth": 100,
	"singleQuote": false,
	"jsxSingleQuote": false,
	"semi": true,
	"sortImports": {
		"groups": [
			"builtin",
			"external",
			["internal", "subpath"],
			["parent", "sibling", "index"],
			"style",
			"unknown"
		]
	},
	"sortTailwindcss": {
		"attributes": ["className"],
		"functions": ["cn"],
		"stylesheet": "./tooling/tailwind/theme.css"
	},
	"sortPackageJson": true,
	"overrides": [
		{
			"files": ["**/*.json"],
			"options": {
				"trailingComma": "none"
			}
		}
	],
	"ignorePatterns": [
		"apps/marketing/routeTree.gen.ts",
		"apps/saas/routeTree.gen.ts",
		"apps/docs/src/routeTree.gen.ts",
		"apps/marketing/.content-collections/**"
	]
}
