# ---- Database ---------------------------------------------------------------
DATABASE_URL="YOUR_DATABASE_CONNECTION_STRING"
# For local development with Docker Compose:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/supastarter"
# ... if you use Supabase pooler + direct url
DIRECT_URL=""

# ---- App URLs ---------------------------------------------------------------
# Use the VITE_ prefix for variables exposed to the browser. Keep this file at
# the monorepo root; apps/saas and apps/marketing vite.config set envDir here.
VITE_MARKETING_URL="http://localhost:3001"
VITE_SAAS_URL="http://localhost:3000"
VITE_DOCS_URL="http://localhost:3002"

# ---- Authentication ---------------------------------------------------------
# Generate a new one with `openssl rand -hex 32`.
BETTER_AUTH_SECRET="A_RANDOM_SECRET_STRING"
# ... for GitHub OAuth
GITHUB_CLIENT_ID="YOUR_GITHUB_CLIENT_ID"
GITHUB_CLIENT_SECRET="YOUR_GITHUB_CLIENT_SECRET"
# ... for Google OAuth
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"

# ---- Email ------------------------------------------------------------------
MAIL_FROM="noreply@example.com"
# ... with nodemailer (SMTP)
MAIL_HOST=""
MAIL_PORT=""
MAIL_USER=""
MAIL_PASS=""
# ... with Plunk
PLUNK_API_KEY=""
# ... with Resend
RESEND_API_KEY=""
# ... with Postmark
POSTMARK_SERVER_TOKEN=""
# ... with Mailgun
MAILGUN_API_KEY=""
MAILGUN_DOMAIN=""

# ---- Payments ---------------------------------------------------------------
# ... with Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# ... with Lemonsqueezy
LEMONSQUEEZY_API_KEY=""
LEMONSQUEEZY_WEBHOOK_SECRET=""
LEMONSQUEEZY_STORE_ID=""
# ... with Creem
CREEM_API_KEY=""
CREEM_WEBHOOK_SECRET=""
# ... with Polar
POLAR_ACCESS_TOKEN=""
POLAR_WEBHOOK_SECRET=""
# ... with DodoPayments
DODO_PAYMENTS_API_KEY=""
DODO_PAYMENTS_WEBHOOK_SECRET=""

# Product price ids (obtained from your payment provider dashboard).
PRICE_ID_PRO_MONTHLY="price_asdf1234"
PRICE_ID_PRO_YEARLY="price_asdf1234"
PRICE_ID_LIFETIME="price_asdf1234"

# ---- Analytics --------------------------------------------------------------
# ... for Plausible: domain registered in Plausible.
VITE_PLAUSIBLE_URL=""
# ... for Umami
VITE_UMAMI_WEBSITE_ID=""
VITE_UMAMI_SRC="https://analytics.eu.umami.is/script.js"
# ... for Pirsch
VITE_PIRSCH_CODE=""
# ... for Google Analytics
VITE_GOOGLE_ANALYTICS_ID=""
# ... for Mixpanel
VITE_MIXPANEL_TOKEN=""
# ... for PostHog
VITE_POSTHOG_KEY=""
VITE_POSTHOG_HOST="https://us.i.posthog.com"

# ---- Storage (S3-compatible) ------------------------------------------------
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_ENDPOINT=""
S3_REGION=""
VITE_AVATARS_BUCKET_NAME="avatars"
# For local development with Docker Compose (MinIO):
# S3_ACCESS_KEY_ID="minioadmin"
# S3_SECRET_ACCESS_KEY="minioadmin"
# S3_ENDPOINT="http://localhost:9000"
# S3_REGION="us-east-1"

# ---- AI ---------------------------------------------------------------------
# ... with OpenAI
OPENAI_API_KEY=""
